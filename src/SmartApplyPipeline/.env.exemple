ENV=development

# MongoDB
MONGODB_URI=mongodb://admin:changeme_en_prod@smartapply-db:27017/jobpipeline?authSource=admin
MONGODB_DB=jobpipeline

# JWT (same secret as auth-service)
JWT_SECRET_KEY=genere_avec_openssl_rand_hex_32


# External job APIs
JSEARCH_API_KEY=
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# Cache TTL
JOB_CACHE_TTL_HOURS=12


# RAG
RAG_URL=http://rag:8001
RAG_TIMEOUT=120

# Scraping
HUNTER_API_KEY=
SCRAPING_MAX_RESULTS=100

# Pipeline config
MIN_PRESCORE=4
MIN_DEEP_SCORE=5
CONCURRENCY=10
TIMEOUT_HTTP=6
PAUSE=0.3
MAX_WORKERS=5

# Ollama (deep filter)
OLLAMA_MODEL=mistral
OLLAMA_HOST=http://host.docker.internal:11434


GMAIL_URL=http://gmail:8002
