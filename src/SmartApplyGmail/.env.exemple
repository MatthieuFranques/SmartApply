ENV=development

# Google OAuth 2.0 (read-only — tokens are stored in MongoDB by auth-service)
GOOGLE_CLIENT_ID=ton_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=ton_client_secret

# MongoDB
MONGODB_URI=mongodb://admin:changeme_en_prod@smartapply-db:27017/jobpipeline?authSource=admin
MONGODB_DB=jobpipeline

# JWT (same secret as auth-service)
JWT_SECRET_KEY=genere_avec_openssl_rand_hex_32

# RAG (for draft generation)
RAG_URL=http://rag:8001
RAG_TIMEOUT=120

# Pipeline (for company data)
PIPELINE_URL=http://smartapply-pipeline:8002

# Gmail
GMAIL_LABEL=Candidatures
GMAIL_MAX_RESULTS=50

# Ollama (email parser)
OLLAMA_MODEL=mistral
OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_TEMPERATURE=0.0
OLLAMA_MAX_TOKENS=512
OLLAMA_TIMEOUT=30
OLLAMA_BODY_MAX_CHARS=3000
OLLAMA_SUBJECT_MAX_CHARS=300
OLLAMA_SENDER_MAX_CHARS=200
OLLAMA_FALLBACK_ENABLED=true
OLLAMA_EMAIL_LANGS=fr,en
