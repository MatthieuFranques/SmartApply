# Fichier de configuration pour les variables d'environnement
# Ne pas oublier de créer un fichier .env.local pour les variables sensibles (ex: clés API) et de les ajouter à .gitignore
# Exemple de contenu pour .env.local :

ENV=development
# SCRAPING

HUNTER_API_KEY=

# JSearch (RapidAPI) — Indeed job search — free 200 req/month
# https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
JSEARCH_API_KEY=""

# Adzuna — official job API — free 250 req/day
# https://developer.adzuna.com
ADZUNA_APP_ID=""
ADZUNA_APP_KEY=""

# Job search cache TTL in hours (default 12h)
JOB_CACHE_TTL_HOURS=12

# ── Google OAuth 2.0 ──────────────────────────────────────────
# Récupère ces valeurs sur https://console.cloud.google.com
# Credentials > OAuth 2.0 > Télécharger le JSON client
 
GOOGLE_CLIENT_ID=ton_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=ton_client_secret
GOOGLE_REDIRECT_URI=http://localhost:8000/gmail/callback

GMAIL_LABEL=Candidatures
GMAIL_MAX_RESULTS=50

# MongoDB — credentials identiques à docker-compose
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=changeme_en_prod
MONGODB_DB=jobpipeline
MONGODB_URI=mongodb://admin:changeme_en_prod@smartapply-db:27017/jobpipeline?authSource=admin

# JWT
JWT_SECRET_KEY=genere_avec_openssl_rand_hex_32
 
# Chemin vers le fichier token généré après la 1ère connexion
GMAIL_TOKEN_PATH=token.json
 
SonarProjectKey=

SonarOrganization=


# Pipeline config
MIN_PRESCORE=4
MIN_DEEP_SCORE=5
CONCURRENCY=10
TIMEOUT_HTTP=6
PAUSE=0.3
MAX_WORKERS=5
SCRAPING_MAX_RESULTS=100

GMAIL_LABEL = "Candidatures"
GMAIL_MAX_RESULTS = 1000

# ══════════════════════════════════════════════════════
# OLLAMA — configuration du service de parsing email
# ══════════════════════════════════════════════════════

# Modèle Ollama à utiliser (mistral, llama3, phi3, gemma2, etc.)
OLLAMA_MODEL=mistral

# URL de l'instance Ollama (local par défaut, peut pointer vers un serveur distant)
OLLAMA_HOST=http://localhost:11434

# Température : 0.0 = déterministe, 0.7 = créatif
OLLAMA_TEMPERATURE=0.0

# Nombre maximum de tokens générés en réponse
OLLAMA_MAX_TOKENS=512

# Timeout en secondes pour chaque appel au modèle
OLLAMA_TIMEOUT=30

# Taille max du corps de l'email envoyé au modèle (en caractères)
# Augmenter si des infos importantes sont en bas des emails
OLLAMA_BODY_MAX_CHARS=3000

# Taille max du sujet envoyé au modèle
OLLAMA_SUBJECT_MAX_CHARS=300

# Taille max de l'expéditeur envoyé au modèle
OLLAMA_SENDER_MAX_CHARS=200


OLLAMA_FALLBACK_ENABLED=true

OLLAMA_EMAIL_LANGS=fr,en